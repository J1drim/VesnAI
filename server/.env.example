# VesnAI environment configuration — copy to .env (same directory you run
# `vesnai serve` from). Every key mirrors a vesnai.yaml setting; the yaml file
# (see vesnai.example.yaml) is the recommended single place to configure the
# server, and env vars override it.

# --- storage ----------------------------------------------------------------
#VESNAI_KNOWLEDGE_DIR=./knowledge
#VESNAI_DATA_DIR=./data
#VESNAI_MODELS_CACHE_DIR=./models

# --- network ------------------------------------------------------------------
#VESNAI_HOST=127.0.0.1
#VESNAI_PORT=8443
#VESNAI_TLS_ENABLED=true
#VESNAI_TLS_CERT_FILE=
#VESNAI_TLS_KEY_FILE=
#VESNAI_ADVERTISE_MDNS=true

# --- mode ---------------------------------------------------------------------
# true = offline demo with fake AI; false = real providers below.
#VESNAI_OFFLINE_ONLY=true

# --- LLM ------------------------------------------------------------------
#VESNAI_LLM_PROVIDER=ollama            # ollama | openai_compatible
#VESNAI_LLM_BASE_URL=                  # e.g. https://api.openai.com/v1
#VESNAI_LLM_API_KEY=                   # literal or env:VAR_NAME
#VESNAI_DEFAULT_CHAT_MODEL=qwen3.6
#VESNAI_DEFAULT_REASONING_MODEL=qwen3.6
#VESNAI_MARENA_MODEL=                  # empty = inherit reasoning model
#VESNAI_DEFAULT_VISION_MODEL=qwen3.6
#VESNAI_DEFAULT_EMBEDDING_MODEL=bge-m3
#VESNAI_EMBEDDING_DIM=1024
#VESNAI_OLLAMA_HOST=
#VESNAI_OLLAMA_AUTO_PULL=true

# --- components -------------------------------------------------------------
#VESNAI_TTS_ENGINE=remote              # remote | chatterbox | none
#VESNAI_STT_ENGINE=whisper             # whisper | none
#VESNAI_STT_MODEL=large-v3
#VESNAI_IMAGE_ENGINE=flux              # flux | none
#VESNAI_FLUX_MODEL=schnell
#VESNAI_HF_TOKEN=                      # for the gated official FLUX repo
#VESNAI_AUTO_ILLUSTRATE=true
#VESNAI_VECTOR_STORE=auto              # auto | qdrant | in_memory
#VESNAI_QDRANT_URL=http://127.0.0.1:6333
#VESNAI_SEARCH_ENGINE=searxng          # searxng | none
#VESNAI_SEARXNG_URL=http://127.0.0.1:8888

# --- Marena critic ------------------------------------------------------------
#VESNAI_MARENA_ENABLED=true
#VESNAI_MARENA_INTERVAL_HOURS=6
